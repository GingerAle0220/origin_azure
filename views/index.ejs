<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>MY FAVORITES</title>
  <link rel="stylesheet" href="/css/style.css">

  <script>
    (function(d) {
      var config = {
        kitId: 'szk7bkb',
        scriptTimeout: 3000,
        async: true
      },
      h=d.documentElement,t=setTimeout(function(){h.className=h.className.replace(/\bwf-loading\b/g,"")+" wf-inactive";},config.scriptTimeout),tk=d.createElement("script"),f=false,s=d.getElementsByTagName("script")[0],a;h.className+=" wf-loading";tk.src='https://use.typekit.net/'+config.kitId+'.js';tk.async=true;tk.onload=tk.onreadystatechange=function(){a=this.readyState;if(f||a&&a!="complete"&&a!="loaded")return;f=true;clearTimeout(t);try{Typekit.load(config)}catch(e){}};s.parentNode.insertBefore(tk,s)
    })(document);
  </script>
</head>
<body>

  <!-- ===== OPENING OVERLAY ===== -->
  <div id="opening-overlay">
    <div class="opening-inner">
      <div class="op-line" data-delay="0">
        <span class="op-box" style="background:#f5a623;">📚</span>
        <span class="op-text">好きな本を紹介</span>
      </div>
      <div class="op-line" data-delay="1">
        <span class="op-box" style="background:#d0021b;">👻</span>
        <span class="op-text">ホラーゲームを紹介</span>
      </div>
      <div class="op-line" data-delay="2">
        <span class="op-box" style="background:#7b00ff;">❓</span>
        <span class="op-text">？？？を紹介</span>
      </div>
      <div class="op-subtitle" data-delay="3">コインをクリックして運命を決めよう</div>
    </div>
  </div>

  <!-- ===== MAIN SITE ===== -->
  <div id="main-site" class="hidden">

    <!-- ヘッダー＆コインエリア -->
    <header id="top-section">
      <div class="header-bg-text">MY FAVORITES</div>
      <h1 class="site-title">MY FAVORITES</h1>
      <p class="site-subtitle">運命のコインをクリックして世界を選べ</p>

      <div class="coin-wrapper">
        <div id="coin-container">
          <!-- 表(sun)を初期表示 -->
          <img id="coin-img" src="/images/coin_sun.png" alt="コイン表面">
        </div>
        <p id="coin-hint">✨ クリックでコインを回す</p>
        <div id="result-badge" class="hidden"></div>
      </div>
    </header>

    <!-- ===== BOOK SECTION (ライトモード) ===== -->
    <section id="book-section" class="content-section light-mode hidden">
      <div class="section-header light">
        <span class="section-num">01</span>
        <h2>📚 好きな本</h2>
        <p class="section-desc">中学生の時の朝読書から本が好きになりました</p>
      </div>
      <div class="cards-grid">
        <% books.forEach((book, i) => { %>
        <article class="card light-card" style="animation-delay: <%= i * 0.12 %>s">
          <div class="card-image-wrap">
            <img src="<%= book.image %>" alt="<%= book.book_name %>" class="card-img"
              onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
            <div class="card-img-fallback"><span>📖</span></div>
          </div>
          <div class="card-body">
            <h3 class="card-title"><%= book.book_name %></h3>
            <div class="card-meta">
              <span>✍ <%= book.writer %></span>
              <span>🏢 <%= book.publisher %></span>
              <span>📅 <%= book.year %>年</span>
            </div>
            <p class="card-overview"><%= book.book_overview %></p>
            <div class="card-comment">
              <span class="comment-label">📝 コメント</span>
              <p><%= book.my_comment %></p>
            </div>
          </div>
        </article>
        <% }) %>
      </div>
    </section>

    <!-- ===== HORROR GAME SECTION (ダークモード) ===== -->
    <section id="horror-section" class="content-section dark-mode hidden">
      <div class="section-header dark">
        <span class="section-num">02</span>
        <h2>👻 ホラーゲーム</h2>
        <p class="section-desc">ホラーゲームはやったことない．動画を見ることしかできない...</p>
      </div>
      <div class="cards-grid">
        <% horaGames.forEach((game, i) => { %>
        <article class="card dark-card" style="animation-delay: <%= i * 0.12 %>s">
          <div class="card-image-wrap">
            <img src="<%= game.image %>" alt="<%= game.game_name %>" class="card-img"
              onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
            <div class="card-img-fallback dark"><span>🎮</span></div>
          </div>
          <div class="card-body">
            <span class="game-number"># <%= game.number %></span>
            <h3 class="card-title"><%= game.game_name %></h3>
            <div class="card-meta dark-meta">
              <span>🛠 <%= game.developer %></span>
            </div>
            <p class="card-overview"><%= game.overview %></p>
            <div class="card-comment dark-comment">
              <span class="comment-label">💬 コメント</span>
              <p><%= game.my_comment %></p>
            </div>
          </div>
        </article>
        <% }) %>
      </div>
    </section>

    <!-- ===== PACHINKO SECTION (レジェンド) ===== -->
    <section id="pachinko-section" class="content-section legend-mode hidden">
      <div class="section-header legend">
        <span class="section-num legend-num">★</span>
        <h2>🎰 パチンコ LEGEND</h2>
        <p class="section-desc">レジェンドコイン出現！大好きな台を紹介</p>
      </div>
      <div class="cards-grid">
        <% pachinkoList.forEach((p, i) => { %>
        <article class="card legend-card" style="animation-delay: <%= i * 0.15 %>s">
          <div class="card-image-wrap">
            <img src="<%= p.image %>" alt="<%= p.name %>" class="card-img"
              onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
            <div class="card-img-fallback legend-fallback"><span>🎰</span></div>
          </div>
          <div class="card-body">
            <h3 class="card-title legend-title"><%= p.name %></h3>
            <div class="card-meta legend-meta">
              <span>🏭 <%= p.maker %></span>
            </div>
            <div class="card-comment legend-comment">
              <span class="comment-label">⭐ オススメポイント</span>
              <p><%= p.comment %></p>
            </div>
          </div>
        </article>
        <% }) %>
      </div>
    </section>

    <!-- ===== BULLETIN BOARD SECTION ===== -->
    <section id="board-section" class="content-section light-mode">
      <div class="section-header light">
        <span class="section-num">MSG</span>
        <h2>💬 掲示板</h2>
        <p class="section-desc">好きな本やホラーゲームについて語りましょう！</p>
      </div>
      
      <div class="board-container">
        <!-- Message form -->
        <form id="board-form" class="board-form">
          <div class="form-group">
            <input type="text" id="board-name" placeholder="ニックネーム" required maxlength="20">
          </div>
          <div class="form-group">
            <textarea id="board-msg" placeholder="メッセージを入力してください..." required rows="3"></textarea>
          </div>
          <button type="submit" class="board-submit-btn">送信</button>
        </form>

        <!-- Message List -->
        <ul id="board-messages" class="board-messages">
          <!-- Messages will be injected here via socket.io -->
        </ul>
      </div>
    </section>

    <footer>
      <p>© 2026 MY FAVORITES — コインを回してまた遊びに来てね</p>
    </footer>

  </div><!-- /main-site -->

  <script src="/socket.io/socket.io.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>
